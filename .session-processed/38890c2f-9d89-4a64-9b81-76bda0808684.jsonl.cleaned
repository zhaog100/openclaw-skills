    for part_file in \"$MEMORY_DIR\"/part*.json; do\n/root/.openclaw/workspace/skills/session-memory-enhanced/scripts/session-memory-enhanced-v3.1.sh:16:TAIL_FILE=\"$MEMORY_DIR/.tail.tmp.json\"\n/root/.openclaw/workspace/skills/session-memory-enhanced/scripts/session-memory-enhanced-v3.1.sh:61:    local part_num=$(ls \"$MEMORY_DIR\"/part*.json 2>/dev/null | wc -l)\n/root/.openclaw/workspace/skills/session-memory-enhanced/scripts/session-memory-enhanced-v3.1.sh:62:    local part_file=\"$MEMORY_DIR/part$(printf '%03d' $part_num).json\"\n/root/.openclaw/workspace/skills/session-memory-enhanced/scripts/session-memory-enhanced-v3.2.sh:16:TAIL_FILE=\"$MEMORY_DIR/.tail.tmp.json\"\n/root/.openclaw/workspace/skills/session-memory-enhanced/scripts/session-memory-enhanced-v3.2.sh:64:    local part_num=$(ls \"$MEMORY_DIR\"/part*.json 2>/dev/null | wc -l)\n/root/.openclaw/workspace/skills/session-memory-enhanced/scripts/session-memory-enhanced-v3.2.sh:65:    local part_file=\"$MEMORY_DIR/part$(printf '%03d' $part_num).json\"",
